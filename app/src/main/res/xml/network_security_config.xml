<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!--
        Production domains — use system trust store (standard SSL).
        Replace these with your actual backend domains when ready.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">goosebumps.com</domain>
        <domain includeSubdomains="true">geoapify.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!--
        Debug / local development — allows HTTP and self-signed certs.
        This block only applies to debug builds via the manifest's
        android:networkSecurityConfig attribute.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.63.82.216</domain>
        <domain includeSubdomains="true">172.18.191.254</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Base config — deny cleartext everywhere else in production -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

</network-security-config>
